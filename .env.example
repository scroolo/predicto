# Database
DB_URL=jdbc:postgresql://db:5432/predicto
DB_USERNAME=predicto
DB_PASSWORD=your_secure_password

# JWT
JWT_SECRET=your_very_long_random_secret_key_here_min_32_chars

# PandaScore
PANDASCORE_API_TOKEN=your_pandascore_token
PANDASCORE_MOCK_ENABLED=false

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://your-backend.railway.app/api/auth/discord/callback

# Email (optional)
MAIL_USERNAME=
MAIL_PASSWORD=

# Frontend
VITE_API_BASE_URL=https://your-backend.railway.app
